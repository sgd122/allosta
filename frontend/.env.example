# NestJS backend URL (server-side only — never exposed to the client bundle).
NESTJS_URL=http://localhost:3000

# Must equal the backend's JWT_SECRET. The Next.js middleware verifies the
# session JWT's signature + expiry with this value before serving any protected
# page. Mirror backend/.env (default there: dev-only-change-me-in-production).
JWT_SECRET=dev-only-change-me-in-production

# The seeded counselor's id. The backend seed script (prisma/seed.ts) prints
# this on `pnpm prisma db seed` as `counselorId`. Paste it here so the customer
# booking page can pre-fill the counselor field. If left blank, the booking page
# shows a visible input so the evaluator can paste it manually.
NEXT_PUBLIC_DEMO_COUNSELOR_ID=
