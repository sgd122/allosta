// Allosta counseling booking platform — data model (plan §7).
//
// CONCURRENCY (AC15/AC2): A partial unique index enforces "at most one ACTIVE
// Booking per slot", where ACTIVE = status IN ('PENDING','CONFIRMED'). This
// covers the PENDING-first flow: two customers cannot both preempt the same
// slot. CANCELLED and COMPLETED bookings leave the index, reopening the slot.
// Prisma cannot express partial unique indexes in this schema, so it is created
// via raw SQL in the migration `booking_pending_first`:
//   CREATE UNIQUE INDEX "booking_slot_active_unique"
//     ON "Booking"("slotId") WHERE "status" IN ('PENDING','CONFIRMED');
// Booking creation uses an insert-first / catch-23505 pattern that maps the
// unique violation to a 409 ConflictException (see booking.service.ts).
//
// FAMILY LINK (symmetric, AC1-AC10): FamilyLink connects two Customer accounts
// symmetrically. Partial unique index enforces at most one ACCEPTED link per
// pair (normalized as sorted customerLowId/customerHighId):
//   CREATE UNIQUE INDEX "family_link_accepted_pair_unique"
//     ON "FamilyLink"("customerLowId","customerHighId") WHERE status = 'ACCEPTED';
// PENDING rows have a null inviteeCustomerId so pair normalization is deferred
// to accept time. Accept uses UPDATE+catch-P2002 (see family.service.ts).
//
// CUSTOMER SELF-OVERLAP (ADR 0015): the partial unique index above only stops two
// bookings on the SAME slotId — it does NOT stop one customer from holding two
// ACTIVE bookings on DIFFERENT slots (different counselors) at the same/overlapping
// time. A person cannot attend two consultations at once. Because slot durations
// vary (30/60min), this is enforced as a time-RANGE overlap via a Postgres GiST
// EXCLUDE constraint (btree_gist), partial on the ACTIVE set, created in raw SQL
// (Prisma cannot express exclusion constraints) in migration
// `customer_no_overlap`:
//   ALTER TABLE "Booking" ADD CONSTRAINT "booking_customer_no_overlap"
//     EXCLUDE USING gist ("customerId" WITH =, tsrange("slotStartAt","slotEndAt") WITH &&)
//     WHERE ("status" IN ('PENDING','CONFIRMED'));
// Booking.slotStartAt/slotEndAt below are the denormalized slot window the
// constraint ranges over.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  COUNSELOR
  ADMIN
}

enum SubjectType {
  CUSTOMER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum Outcome {
  EXPLAINED
  GUIDED
  PURCHASED
}

// Call attempt result for CallLog (contact-surfacing evidence layer, ADR 0016).
// CONNECTED = reached the customer; NO_ANSWER = dialed, no pickup; INVALID =
// number unreachable/wrong. Structured enum (never free text) so the attempt is
// aggregatable without surfacing the call note. CallLog is loosely coupled to
// attendance: it is evidence only and NEVER writes Booking.status.
enum CallOutcome {
  CONNECTED
  NO_ANSWER
  INVALID
}

enum ConsultationActionType {
  METRIC_EXPLAINED
  DIET_GUIDANCE
  SUPPLEMENT_GUIDANCE
  RETEST_GUIDANCE
  LIFESTYLE_GUIDANCE
}

enum NotificationType {
  CONFIRMATION
  REMINDER
  SLOT_OPENED
}

enum NotificationChannel {
  CONSOLE
  IN_APP
  EMAIL
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum FamilyLinkStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())

  customer  Customer?
  counselor Counselor?
}

model Customer {
  id     String @id @default(cuid())
  userId String @unique
  name   String
  phone  String

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  inviterLinks FamilyLink[]          @relation("InviterLinks")
  inviteeLinks FamilyLink[]          @relation("InviteeLinks")
  enrollments  ChallengeEnrollment[]
  qaSessions   QaSession[]
}

model Counselor {
  id        String @id @default(cuid())
  userId    String @unique
  name      String
  specialty String

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  slots       AvailabilitySlot[]
  records     ConsultationRecord[]
  enrollments ChallengeEnrollment[]
  callLogs    CallLog[]
}

model AvailabilitySlot {
  id          String   @id @default(cuid())
  counselorId String
  startAt     DateTime
  endAt       DateTime
  // `isOpen` is an operational flag (counselor opens/closes the slot).
  // It does NOT encode "is booked" — availability is derived as:
  // slot exists AND isOpen AND has no CONFIRMED Booking (plan §2.3 single-source-of-truth).
  isOpen      Boolean  @default(true)

  counselor Counselor @relation(fields: [counselorId], references: [id], onDelete: Cascade)
  bookings  Booking[]

  @@index([counselorId])
}

model Booking {
  id            String        @id @default(cuid())
  slotId        String
  customerId    String
  subjectType   SubjectType
  subjectId     String
  // The test result the consultation is about. Nullable for legacy bookings
  // created before the calendar redesign; new bookings always set it, and the
  // subject (subjectType/subjectId) is derived from this result's owner.
  testResultId  String?
  status        BookingStatus @default(PENDING)
  // Optional customer pre-question (사전질문). Surfaced write-only into the
  // counselor brief (consultation prep, ADR 0014) — never read back to the
  // customer. Length-bounded at the DTO layer (@MaxLength).
  concern       String?
  // First time the assigned counselor opened the pre-consultation brief
  // (brief-open-rate numerator, AC-P7). Set once via a conditional updateMany
  // (briefOpenedAt: null guard) so concurrent opens stay DB-idempotent.
  briefOpenedAt DateTime?
  // Denormalized copy of the booked slot's [startAt, endAt) window. The slot time
  // lives on AvailabilitySlot, but the `booking_customer_no_overlap` GiST EXCLUDE
  // constraint (ADR 0015) must range over a single Booking row, so it is mirrored
  // here. Write-once at create() — bookings never reschedule their slot. If a
  // reschedule feature is ever added it MUST update these columns to keep them in
  // sync with the source slot.
  slotStartAt   DateTime
  slotEndAt     DateTime
  createdAt     DateTime      @default(now())

  // NOTE: the partial unique index on (slotId) WHERE status IN ('PENDING','CONFIRMED')
  // is added via raw SQL migration (see header comment) — it is what enforces
  // AC15/AC2 (at most one ACTIVE booking per slot, covering PENDING preemption).
  // A second raw-SQL constraint, booking_customer_no_overlap (GiST EXCLUDE over
  // customerId + tsrange(slotStartAt, slotEndAt), partial on ACTIVE), enforces
  // that one customer cannot hold two overlapping ACTIVE bookings (ADR 0015).

  slot          AvailabilitySlot           @relation(fields: [slotId], references: [id], onDelete: Cascade)
  customer      Customer                   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  testResult    TestResult?                @relation(fields: [testResultId], references: [id], onDelete: SetNull)
  record        ConsultationRecord?
  notifications Notification[]
  // Pre-consultation AI guidance (ADR 0014). Advises the counselor how to
  // conduct the UPCOMING consultation, keyed by bookingId @unique. Distinct from
  // any post-consultation artifact — generated/refreshed lazily on brief open.
  aiGuidance    ConsultationBriefGuidance?
  // Call attempt evidence (ADR 0016). Loosely coupled — logging a call never
  // mutates this booking's status (P5); attendance stays single-source-of-truth.
  callLogs      CallLog[]

  @@index([slotId])
  @@index([customerId])
  @@index([testResultId])
}

model ConsultationRecord {
  id             String                   @id @default(cuid())
  bookingId      String                   @unique
  counselorId    String
  summary        String
  recommendation String
  followUp       String?
  actions        ConsultationActionType[] @default([])
  outcome        Outcome
  createdAt      DateTime                 @default(now())

  booking     Booking                     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  counselor   Counselor                   @relation(fields: [counselorId], references: [id], onDelete: Cascade)
  products    ConsultationRecordProduct[]
  metrics     ConsultationRecordMetric[]
  enrollments ChallengeEnrollment[]

  @@index([counselorId])
}

// Call attempt evidence (contact-surfacing, ADR 0016). A counselor records each
// click-to-call attempt against the booking so a no-show override has evidence.
// NON-DESTRUCTIVE & loosely coupled (P1/P5): creating a CallLog NEVER writes
// Booking.status — attendance remains single-source-of-truth on Booking, mutated
// only by PATCH /bookings/:id/attendance. `outcome` is a forced enum (no free
// text classification). `note` is an optional short memo, length-bounded at the
// DTO layer like Booking.concern; it is PII-adjacent and never logged or surfaced
// in any admin aggregation (aggregations read `outcome` only).
model CallLog {
  id          String      @id @default(cuid())
  bookingId   String
  counselorId String
  outcome     CallOutcome
  note        String?
  createdAt   DateTime    @default(now())

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  counselor Counselor @relation(fields: [counselorId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([counselorId])
}

// Pre-consultation AI guidance (ADR 0014). Advises the counselor how to conduct
// the UPCOMING consultation, derived from the subject's test indicators + prior
// consultation records + the customer's concern. Keyed by bookingId @unique.
//
// Generated lazily on brief open: the deterministic template FALLBACK is upserted
// the first time the counselor opens the brief (never overwriting an existing
// UPGRADED row). The OpsScheduler @Interval sweep upgrades FALLBACK rows to
// UPGRADED when local Ollama (gemma) is detected. The row's absence means
// "not yet generated" without a sentinel; `status` drives the lifecycle.
// Reproducibility: the template FALLBACK keeps the golden path Ollama-independent.
enum BriefGuidanceStatus {
  FALLBACK
  UPGRADED
}

model ConsultationBriefGuidance {
  id        String              @id @default(cuid())
  bookingId String              @unique
  status    BriefGuidanceStatus @default(FALLBACK)
  // The gemma model name when UPGRADED; null on FALLBACK.
  model     String?
  content   String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Product {
  id       String @id @default(cuid())
  name     String
  category String

  records ConsultationRecordProduct[]
}

model ConsultationRecordProduct {
  recordId  String
  productId String

  record  ConsultationRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  product Product            @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([recordId, productId])
  @@index([productId])
}

model TestResult {
  id          String      @id @default(cuid())
  subjectType SubjectType
  subjectId   String
  serviceType String
  metrics     Json
  createdAt   DateTime    @default(now())

  recordMetrics ConsultationRecordMetric[]
  bookings      Booking[]
  qaSessions    QaSession[]

  @@index([subjectType, subjectId])
}

model ConsultationRecordMetric {
  id           String @id @default(cuid())
  recordId     String
  testResultId String
  metricKey    String

  record     ConsultationRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  testResult TestResult         @relation(fields: [testResultId], references: [id], onDelete: Cascade)

  @@index([recordId])
  @@index([testResultId])
}

// BioCom step-3 "관리 프로그램/챌린지" (AC4). Challenge is a seed-managed catalog;
// ChallengeEnrollment is counselor-driven, created atomically inside createRecord.
enum ChallengeEnrollmentStatus {
  IN_PROGRESS
  COMPLETED
  DROPPED
}

model Challenge {
  id                String  @id @default(cuid())
  name              String
  category          String
  description       String
  // Advisory only: a sort/hint for which Challenge fits a serviceType. Never a
  // hard filter — the full catalog is always offered.
  linkedServiceType String?

  enrollments ChallengeEnrollment[]
}

model ChallengeEnrollment {
  id          String                    @id @default(cuid())
  challengeId String
  customerId  String
  // The ConsultationRecord whose creation enrolled the customer (plan B1).
  recordId    String
  // Denormalised for query convenience + the cascade FK. Analytics conversion
  // ALWAYS scopes through the record's counselorId via JOIN, never this in
  // isolation — equal at write time since the record's counselor is the enroller.
  counselorId String
  status      ChallengeEnrollmentStatus @default(IN_PROGRESS)
  enrolledAt  DateTime                  @default(now())

  // All FKs cascade (mirror ConsultationRecordMetric) so deleting a Customer,
  // Counselor, or ConsultationRecord sweeps enrollment rows automatically.
  challenge Challenge          @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  customer  Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  record    ConsultationRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  counselor Counselor          @relation(fields: [counselorId], references: [id], onDelete: Cascade)

  // A record is one-per-booking (bookingId @unique) and creates AT MOST ONE
  // enrollment (single optional challengeId). recordId uniqueness fully bounds
  // it and makes the invariant explicit for the retry-enrollment spec.
  @@unique([recordId])
  @@index([challengeId])
  @@index([customerId])
  @@index([counselorId])
}

model Notification {
  id          String              @id @default(cuid())
  bookingId   String?
  type        NotificationType
  channel     NotificationChannel
  status      NotificationStatus  @default(PENDING)
  scheduledAt DateTime?
  sentAt      DateTime?
  readAt      DateTime?
  createdAt   DateTime            @default(now())

  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([status, scheduledAt])
}

// Symmetric family link — connects two Customer accounts bidirectionally.
// PENDING  = invite code generated by inviter, invitee not yet set.
// ACCEPTED = invitee accepted; customerLowId/customerHighId pair normalised.
// REVOKED  = either party revoked the link.
//
// Pair uniqueness for ACCEPTED links is enforced by a partial unique index
// (see header comment — Prisma cannot express WHERE-clause indexes):
//   CREATE UNIQUE INDEX "family_link_accepted_pair_unique"
//     ON "FamilyLink"("customerLowId","customerHighId") WHERE status = 'ACCEPTED';
model FamilyLink {
  id                String           @id @default(cuid())
  inviterCustomerId String
  inviteeCustomerId String?
  customerLowId     String?
  customerHighId    String?
  relationLowToHigh String?
  relationHighToLow String?
  code              String           @unique
  status            FamilyLinkStatus @default(PENDING)
  expiresAt         DateTime
  createdAt         DateTime         @default(now())
  acceptedAt        DateTime?

  inviter Customer  @relation("InviterLinks", fields: [inviterCustomerId], references: [id], onDelete: Cascade)
  invitee Customer? @relation("InviteeLinks", fields: [inviteeCustomerId], references: [id], onDelete: SetNull)

  @@index([inviterCustomerId])
  @@index([inviteeCustomerId])
  @@index([code])
  @@index([status])
}

// ── Customer-facing AI Q&A on test results (ADR 0018) ───────────────────────
// Additive, interpretation-only Q&A grounded on the customer's own metrics.
// LLM (Ollama reuse) on the critical path with deterministic template fallback.

enum QaMessageRole {
  USER
  ASSISTANT
}

// ASSISTANT message provenance. null on USER turns. FALLBACK_* records WHY the
// deterministic template was used instead of the LLM (analytics + observability).
enum QaMessageSource {
  LLM
  FALLBACK_UNAVAILABLE
  FALLBACK_TIMEOUT
  FALLBACK_SATURATED
  FALLBACK_GUARDRAIL
}

enum QaFeedback {
  YES
  NO
}

model QaSession {
  id           String      @id @default(cuid())
  customerId   String // asker (JWT.customerId), not necessarily the subject
  subjectType  SubjectType // subject snapshot at ask time (deflection attribution accuracy)
  subjectId    String // = Customer.id (self or ACCEPTED family partner)
  testResultId String? // nullable; SetNull on TestResult deletion
  createdAt    DateTime    @default(now())

  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  testResult TestResult? @relation(fields: [testResultId], references: [id], onDelete: SetNull)
  messages   QaMessage[]

  @@index([customerId])
  @@index([customerId, createdAt])
  @@index([subjectType, subjectId]) // subject-attributed deflection query (AC10)
}

model QaMessage {
  id                 String           @id @default(cuid())
  seq                Int              @default(autoincrement()) // monotonic insert order; the deterministic thread sort key. createdAt alone ties because the USER+ASSISTANT rows of one turn are inserted in a single transaction and share CURRENT_TIMESTAMP.
  sessionId          String
  role               QaMessageRole
  text               String
  groundedMetricRefs String[]         @default([]) // cited metricKeys (ASSISTANT). Intentional read-only denormalization — see ADR 0018.
  source             QaMessageSource? // null on USER; ASSISTANT is LLM or FALLBACK_*
  inScope            Boolean? // USER-turn scope classification (false ⇒ decline/escalate)
  feedback           QaFeedback? // ASSISTANT turn, null until rated (AC7)
  createdAt          DateTime         @default(now())

  session QaSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, seq])
}
