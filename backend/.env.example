# PostgreSQL connection (matches root docker-compose.yml)
DATABASE_URL=postgresql://allosta:allosta@localhost:5432/allosta

# JWT
JWT_SECRET=dev-only-change-me-in-production
JWT_EXPIRES_IN=1d

# Notification reminder lead time (minutes before slot start)
REMINDER_LEAD_MINUTES=30

# HTTP port
PORT=3000

# Ollama summarizer
OLLAMA_BASE_URL=http://localhost:11434
SUMMARY_MODEL=gemma4:e4b
# Customer AI Q&A (ADR 0018): short synchronous LLM budget + single-model in-flight cap.
QA_LLM_TIMEOUT_MS=4000
QA_LLM_MAX_INFLIGHT=2
QA_DEFLECTION_WINDOW_DAYS=7
# Per-customer rate limit on the QA write endpoints (POST /qa/sessions, /messages).
# The in-flight cap protects the LLM; this bounds row creation/abuse per customer.
QA_RATELIMIT_TTL=60000
QA_RATELIMIT_LIMIT=30
